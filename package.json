{
  "name": "open-meetup",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "start": "node ./scripts/meetup-cli.cjs start",
    "stop": "node ./scripts/meetup-cli.cjs stop",
    "logs": "node ./scripts/meetup-cli.cjs logs",
    "test": "npm run build && npm run test:server && npm run test:client",
    "test:server": "node --test server/test/*.test.js",
    "test:client": "npm run test --workspace client",
    "build": "cd server && npm run build && cd ../client && npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "sim:bulk-join": "node scripts/bulk-join-simulator/simulate-bulk-join.cjs"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,css,json,md}": [
      "prettier --write"
    ],
    "*.{js,cjs,mjs,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.46.1"
  }
}
